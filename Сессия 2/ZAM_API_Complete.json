    {
      "name": "8. События и Уведомления",
      "item": [
        {
          "name": "Зафиксировать событие",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"BatchId\": 1,\n  \"EventType\": \"Start\",\n  \"Description\": \"Начало производства партии\",\n  \"Source\": \"Production\"\n}"
