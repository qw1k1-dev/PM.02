            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"BatchId\": 1,\n  \"Type\": \"Температурное\",\n  \"Description\": \"Превышение температуры на 5°C\",\n  \"Severity\": \"High\",\n  \"DetectedBy\": \"Иванов И.И.\",\n  \"CorrectiveAction\": \"Снижение нагрева\"\n}"
