{
  "info": {
    "name": "ZAM Production API - Complete",
    "description": "Полное API для управления производством, рецептурами, лабораторными испытаниями",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Аутентификация и Авторизация",
      "item": [
        {
          "name": "Регистрация пользователя",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Login\": \"operator1\",\n  \"Password\": \"pass123\",\n  \"RoleID\": \"1\",\n  \"Email\": \"operator@test.com\",\n  \"FirstName\": \"Иван\",\n  \"LastName\": \"Петров\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "register"]
            }
          }
        },
        {
          "name": "Вход в систему (Авторизация)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Login\": \"operator1\",\n  \"Password\": \"pass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "login"]
            }
          },
          "response": [
            {
              "name": "Успешный вход",
              "originalRequest": {"method": "POST"},
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"xyz123...\",\n  \"role\": \"Admin\",\n  \"userId\": 1,\n  \"login\": \"operator1\",\n  \"message\": \"Login successful\"\n}"
            }
          ]
        },
        {
          "name": "Получить всех пользователей",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/account/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "users"]
            }
          }
        },
        {
          "name": "Получить пользователя по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/account/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "users", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Справочная информация (Роли)",
      "item": [
        {
          "name": "Получить все роли (справочник)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles"]
            }
          }
        },
        {
          "name": "Получить роль по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/roles/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles", "1"]
            }
          }
        },
        {
          "name": "Создать новую роль",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Title\": \"Технолог\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles"]
            }
          }
        },
        {
          "name": "Обновить роль",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Title\": \"Главный технолог\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/roles/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles", "1"]
            }
          }
        },
        {
          "name": "Удалить роль",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/roles/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles", "3"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Рецептуры и Технологические карты",
      "item": [
        {
          "name": "Получить все рецептуры",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/recipes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes"]
