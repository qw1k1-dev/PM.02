        },
        {
          "name": "Получить рецептуру по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/recipes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes", "1"]
            }
          }
        },
        {
          "name": "Создать новую рецептуру",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Title\": \"Хлеб пшеничный\",\n  \"Description\": \"Классический пшеничный хлеб\",\n  \"Ingredients\": \"Мука пшеничная - 1кг, Вода - 600мл, Дрожжи - 10г, Соль - 15г\",\n  \"Instructions\": \"1. Замесить тесто\\n2. Расстойка 2 часа\\n3. Выпечка 40 мин при 200°C\",\n  \"PreparationTime\": 180,\n  \"CookingTime\": 40\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/recipes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes"]
            }
          }
        },
        {
          "name": "Обновить рецептуру",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Title\": \"Хлеб пшеничный улучшенный\",\n  \"Description\": \"С добавлением сахара\",\n  \"Ingredients\": \"Мука - 1кг, Вода - 600мл, Дрожжи - 10г, Соль - 15г, Сахар - 30г\",\n  \"Instructions\": \"Обновленная инструкция\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/recipes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes", "1"]
            }
          }
        },
        {
          "name": "Удалить рецептуру",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/recipes/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recipes", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Производственные задания и партии",
      "item": [
        {
          "name": "Создать производственное задание",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"RecipeId\": 1,\n  \"Quantity\": 500,\n  \"Deadline\": \"2026-05-15\",\n  \"Priority\": \"High\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/production/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "tasks"]
            }
          }
        },
        {
          "name": "Получить все производственные задания",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/production/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "tasks"]
            }
          }
        },
        {
          "name": "Запустить производственную партию",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"RecipeId\": 1,\n  \"Quantity\": 100,\n  \"TaskId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/start",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "start"]
            }
          }
        },
        {
          "name": "Получить все производственные партии",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/production/batches",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches"]
            }
          }
        },
        {
          "name": "Получить партию по ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "1"]
            }
          }
        },
        {
          "name": "Обновить статус партии",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Status\": \"Completed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "1", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Ввод фактических данных цехом",
      "item": [
        {
          "name": "Ввести фактические данные партии",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ActualQuantity\": 98.5,\n  \"Temperature\": 185.5,\n  \"Humidity\": 65.2,\n  \"Pressure\": 101.3,\n  \"OperatorName\": \"Иван Петров\",\n  \"Notes\": \"Небольшое отклонение температуры\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/1/actual",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "1", "actual"]
            }
          }
        },
        {
          "name": "Получить фактические данные партии",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/1/actual",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "1", "actual"]
            }
          }
        },
