          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"BatchId\": 1,\n  \"OperationName\": \"Замес\",\n  \"ActualValue\": \"Консистенция нормальная\",\n  \"IsPassed\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/production/batches/1/operations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "production", "batches", "1", "operations"]
            }
          }
        }
